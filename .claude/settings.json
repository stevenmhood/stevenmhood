      "Bash(aws ecs describe-*)",
      "Bash(aws ecs list-*)",
      "Bash(aws elbv2 describe-*)",
      "Bash(aws events describe-*)",
      "Bash(aws events list-*)",
      "Bash(aws logs describe-*)",
      "Bash(aws logs filter-*)",
