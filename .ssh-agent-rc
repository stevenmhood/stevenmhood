#!/bin/sh

# If SSH_AUTH_SOCK is already set and the socket exists, use it (e.g., Docker agent forwarding)
if [ -n "$SSH_AUTH_SOCK" ] && [ -S "$SSH_AUTH_SOCK" ]; then
    ssh-add -l > /dev/null 2>&1 && return 0 2>/dev/null || true
fi

if [[ -d /System ]]; then
    # Mac
    SSH_AGENT_PID=$(ps -ec | /usr/bin/grep ssh-agent | awk '{print $1}')
else
    # Linux
    SSH_AGENT_PID=$(ps -C ssh-agent --sort +start_time --no-headers | head -n1 | awk '{print $1}')
fi
echo "SSH_AGENT_PID (ps) is [${SSH_AGENT_PID}]"

if [ "x${SSH_AGENT_PID}" = "x" ]; then
    echo "Starting SSH Agent..."
    eval "$(ssh-agent -s)"
else
    echo "SSH Agent using PID ${SSH_AGENT_PID}"
fi

# Find socket
if [[ -d /System ]]; then
    # Mac
    socket=$(ls -t1 $TMPDIR/ssh-*/agent.* | head -n1)
else
    # Linux
    socket=$(ls -t1 $TMPDIR/ssh*/*$((SSH_AGENT_PID-1)) | head -n1)
fi
echo "Agent using socket: $socket"

export SSH_AUTH_SOCK=$socket

agent_has_keys() {
    echo "Checking for keys..."
    ssh-add -l > /dev/null 2>&1
}

if ! agent_has_keys; then
    #sleep 2
    echo "Adding identities..."
    ssh-add
    ssh-add ~/.ssh/id_ed25519
fi
